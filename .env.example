# Optional local overrides for the example scripts.

# Where cloned reference repositories should live.
PROJECTS_DIR=../example-projects

# Optional Agent Canvas checkout. Only needed when USE_SOURCE=1.
AGENT_CANVAS_DIR=../openhands-agent-canvas

# Existing software-agent-sdk checkout, or the clone destination used by setup.
SOFTWARE_AGENT_SDK_DIR=../example-projects/software-agent-sdk

# Optional VS Code example repository. Clone Code OSS / VS Code or point this
# at an existing checkout before running the VS Code example.
VSCODE_REPO_DIR=../example-projects/vscode-benchmark-repo
GITNEXUS_REPO_ALIAS=vscode-benchmark-repo

# Set to 1 if you want setup_example.sh to run npm install in Agent Canvas.
INSTALL_AGENT_CANVAS_DEPS=0

# Set to 1 if you want start_agent_canvas.sh to run the local source checkout.
# The default uses the published @openhands/agent-canvas package through npx.
# Keep this at 0 for the released OpenHands 1.31.0+ MCP path.
USE_SOURCE=0

# Published Agent Canvas package used when USE_SOURCE=0.
AGENT_CANVAS_PACKAGE=@openhands/agent-canvas@latest

# OpenHands Agent Server package used by the Agent Canvas launcher.
OH_AGENT_SERVER_VERSION=1.31.0

# Local Agent Canvas ingress URL used by scripts/test_gitnexus_mcp.sh.
AGENT_CANVAS_URL=http://127.0.0.1:8000

# GitNexus install speed/safety knob. Keeping this at 1 skips optional grammars
# that are not needed for this OpenHands-focused example.
GITNEXUS_SKIP_OPTIONAL_GRAMMARS=1
