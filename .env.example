# Optional local overrides for the example scripts.

# Where cloned example repositories should live.
PROJECTS_DIR=../example-projects

# VS Code / Code OSS repository used by the worked example. Point this at an
# existing checkout, or let scripts/setup_example.sh clone it for you.
VSCODE_REPO_DIR=../example-projects/vscode-benchmark-repo
VSCODE_REMOTE_URL=https://github.com/microsoft/vscode.git
VSCODE_CLONE_DEPTH=1
GITNEXUS_REPO_ALIAS=vscode-benchmark-repo

# Published Agent Canvas package used by scripts/start_agent_canvas.sh.
AGENT_CANVAS_PACKAGE=@openhands/agent-canvas@latest

# OpenHands Agent Server package used by the Agent Canvas launcher.
OH_AGENT_SERVER_VERSION=1.31.0

# Local Agent Canvas ingress URL used by scripts/test_gitnexus_mcp.sh.
AGENT_CANVAS_URL=http://127.0.0.1:8000

# GitNexus install speed/safety knob. Keeping this at 1 skips optional grammars
# that are not needed for this OpenHands-focused example.
GITNEXUS_SKIP_OPTIONAL_GRAMMARS=1
